{
  "name": "ccgs-workflow",
  "version": "2.1.22",
  "description": "Codex-led OpenSpec workflow with Claude Agent Teams execution and local Claude hook monitoring",
  "type": "module",
  "packageManager": "pnpm@10.17.1",
  "author": {
    "name": "CCGS"
  },
  "license": "MIT",
  "keywords": [
    "claude",
    "codex",
    "multi-model",
    "ai",
    "collaboration",
    "cli",
    "workflow"
  ],
  "bin": {
    "ccgs": "bin/ccgs.mjs",
    "ccg": "bin/ccg.mjs"
  },
  "main": "dist/index.mjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.mts",
  "files": [
    "bin/ccgs.mjs",
    "bin/ccg.mjs",
    "claude-monitor/",
    "dist",
    "templates/commands/clean-branches.md",
    "templates/commands/commit.md",
    "templates/commands/enhance.md",
    "templates/commands/init.md",
    "templates/commands/rollback.md",
    "templates/commands/worktree.md",
    "templates/commands/spec-init.md",
    "templates/commands/spec-research.md",
    "templates/commands/spec-plan.md",
    "templates/commands/spec-impl.md",
    "templates/commands/spec-review.md",
    "templates/commands/team-plan.md",
    "templates/commands/team-exec.md",
    "templates/commands/team-review.md",
    "templates/commands/context.md",
    "templates/commands/agents/",
    "templates/codex-skills/",
    "templates/prompts/codex/",
    "templates/prompts/claude/",
    "templates/output-styles/",
    "templates/skills/",
    "templates/rules/"
  ],
  "scripts": {
    "dev": "tsx src/cli.ts",
    "build": "unbuild",
    "monitor:build": "npm --prefix claude-monitor/client run build",
    "monitor:start": "node claude-monitor/server/index.js",
    "monitor:test": "node --test claude-monitor/server/__tests__/*.test.js && npm --prefix claude-monitor/client run test",
    "start": "node bin/ccgs.mjs",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm build",
    "test": "vitest run",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "dependencies": {
    "ansis": "^4.1.0",
    "cac": "^6.7.14",
    "fs-extra": "^11.3.2",
    "i18next": "^25.5.2",
    "i18next-fs-backend": "^2.6.0",
    "inquirer": "^12.9.6",
    "ora": "^9.0.0",
    "pathe": "^2.0.3",
    "smol-toml": "^1.4.2"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild"]
  },
  "devDependencies": {
    "@antfu/eslint-config": "^5.4.1",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^22.0.0",
    "eslint": "^9.36.0",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "unbuild": "^3.6.1",
    "vitepress": "^1.6.4",
    "vitest": "^3.1.1"
  }
}
